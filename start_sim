#!/bin/bash
# Wrapper script to run start_sim_container_config.py using the pysim venv

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_PYTHON="/home/ht/docker/pysim/venv/bin/python3"

if [ ! -f "$VENV_PYTHON" ]; then
    echo "Error: pysim venv not found at $VENV_PYTHON" >&2
    exit 1
fi

exec "$VENV_PYTHON" "$SCRIPT_DIR/start_sim_container_config.py" "$@"
