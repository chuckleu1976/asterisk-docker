            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sim_id\": \"{{sim_id}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/calls/hangup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "calls",
                "hangup"
              ]
            }
