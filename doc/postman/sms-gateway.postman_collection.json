              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone_number\": \"+8618126101015\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/sim-cards/{{sim_id}}/phone",
