        },
        {
          "name": "Set SMS Storage",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"storage\": \"SIM\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/sims/{{sim_id}}/storage",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "sims",
                "{{sim_id}}",
                "storage"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Calls",
      "item": [
        {
          "name": "Get Calls",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/calls?limit=50&offset=0",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "calls"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          }
        },
        {
          "name": "Get Calls By SIM",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/calls?sim_id={{sim_id}}&limit=50",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "calls"
              ],
              "query": [
                {
                  "key": "sim_id",
                  "value": "{{sim_id}}"
                },
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            }
          }
        },
        {
          "name": "Make Call",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sim_id\": \"{{sim_id}}\",\n  \"phone\": \"{{phone}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/calls/make",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "calls",
                "make"
              ]
            }
          }
        },
        {
          "name": "Answer Call",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sim_id\": \"{{sim_id}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/calls/answer",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "calls",
                "answer"
              ]
            }
          }
        },
