# =============================================
# VoWiFi Pi Production Deployment - .env file
# Copy this to .env and fill in your values
# =============================================

# SIM Mode: "remote" = osmo-remsim, "local" = USB reader
SIM_MODE=remote

# Remote remsim-server (used when SIM_MODE=remote)
REMSIM_SERVER=192.168.31.68
REMSIM_PORT=9998
REMSIM_CLIENT_ID=0
REMSIM_SLOT=0
