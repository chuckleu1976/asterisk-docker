# SIM connection mode for the pcscd container
#
# remote  (default) - Remote SIM via osmo-remsim IFD handler
#                     Requires remsim/libs, remsim/serial, remsim/reader.conf.d
# local             - Local USB smart card reader attached to the host machine
#                     pcscd will auto-detect any CCID/USB reader
#
SIM_MODE=local

# Source directory for building the pcscd image locally (optional)
# Only needed when running: docker compose build pcscd
# PCSC_SRC_DIR=/path/to/osmo_remsim_pcsc
